-- ===================== ANIMATIONS =====================
local function openAnimation()
    MainFrame.Size = UDim2.new(0, 300, 0, 380)
    TweenService:Create(MainFrame, TweenInfo.new(0.55, Enum.EasingStyle.Quint), {
        Size = UDim2.new(0, 360, 0, 460),
        BackgroundTransparency = 0
    }):Play()
    TweenService:Create(Stroke, TweenInfo.new(0.6), {Transparency = 0}):Play()
end

local function successClose()
    VerifyButton.Text = "✓ ACCESS GRANTED"
    VerifyButton.BackgroundColor3 = Color3.fromRGB(0, 220, 100)
    
    local tween = TweenService:Create(MainFrame, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {
        Size = UDim2.new(0, 300, 0, 380),
        BackgroundTransparency = 1
    })
    TweenService:Create(Stroke, TweenInfo.new(0.6), {Transparency = 1}):Play()
    tween:Play()
    
    tween.Completed:Connect(function()
        ScreenGui:Destroy()
        for _, v in ipairs(playerGui:GetChildren()) do
            if v.Name == "DiscordPromo" then v:Destroy() end
        end
        print("✅ Key Verified! Loading Main Hub...")
        loadstring(game:HttpGet("https://raw.githubusercontent.com/SCking31/dayi-hub/refs/heads/main/dayihub.lua"))()
    end)
end

-- ===================== BUTTONS =====================
VerifyButton.MouseButton1Click:Connect(function()
    local entered = KeyBox.Text:upper():gsub("%s+", "")
    if entered == "" then return end
    
    Status.Text = "Checking..."
    task.wait(0.9)
    
    if table.find(validKeys, entered) then
        successClose()
    else
        Status.Text = "Invalid Key"
        Status.TextColor3 = Color3.fromRGB(255, 70, 70)
        task.wait(1.4)
        Status.Text = "Ready"
        Status.TextColor3 = Color3.fromRGB(180,180,190)
    end
end)

GetKeyButton.MouseButton1Click:Connect(function()
    setclipboard(DISCORD_LINK)
    GetKeyButton.Text = "COPIED TO CLIPBOARD!"
    GetKeyButton.BackgroundColor3 = Color3.fromRGB(0, 180, 80)
    task.wait(2)
    GetKeyButton.Text = "GET KEY"
    GetKeyButton.BackgroundColor3 = Color3.fromRGB(40,40,50)
end)

KeyBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then VerifyButton.MouseButton1Click:Fire() end
end)

openAnimation()

